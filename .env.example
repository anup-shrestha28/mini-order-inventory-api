# ---------------------------------------------------------------------------
# Copy this file to `.env` (`cp .env.example .env`).
# The defaults below work out-of-the-box with `docker compose up`.
# For local (non-Docker) runs, point MONGO_URI at your MongoDB Atlas cluster.
# ---------------------------------------------------------------------------

# --- Server ---
NODE_ENV=development
PORT=3000

# --- MongoDB ---
# NOTE: The database (mini_order_inventory) and its collections are created
# AUTOMATICALLY on first write. You never create them by hand.
#
# • USING DOCKER (`docker compose up`): leave this line as-is. Compose sets its
#   own MONGO_URI (the bundled Mongo replica set) and IGNORES this value.
#
# • RUNNING LOCALLY WITHOUT DOCKER (`npm run dev`): this value IS used. Point it
#   at a MongoDB you can reach — e.g. MongoDB Atlas (the web version):
#   MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/mini_order_inventory?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/mini_order_inventory

# --- Auth ---
# Change this to a long random string in any real deployment.
JWT_SECRET=change_me_dev_only_secret_please_replace_in_production
JWT_EXPIRES_IN=1d
BCRYPT_SALT_ROUNDS=10

# --- Seed admin (used by `npm run seed`) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin12345

# --- Rate limiting (public endpoints) ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# --- CORS (comma-separated origins, or * for all) ---
CORS_ORIGIN=*

# --- Redis cache (OPTIONAL) ---
# Caching is transparently skipped if REDIS_URL is unset.
# Docker Compose sets this automatically to the bundled Redis.
# REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=60
